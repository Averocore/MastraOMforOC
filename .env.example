# ---- Mastra OM / OpenCode example env ----
# SQLite database file path (relative to project root)
DATABASE_URL=file:./opencode_om.db

# Actor model used by your agent (independent of OM background model)
ACTOR_MODEL=openrouter/xiaomi/mimo-v2-flash

# Optional: override OM background model (default when `observationalMemory: true` is google/gemini-2.5-flash)
# OM_MODEL=google/gemini-2.5-flash

# API Keys (at least one required based on your chosen model)
# OpenRouter API Key (OpenAI format compatible)
OPENROUTER_API_KEY=sk-or-v1-...

# Alternative API keys (if not using OpenRouter)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# GOOGLE_API_KEY=...
